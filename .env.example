# -----------------------------------------------------------------------------
# kicks-js-proxy environment.  Copy to `.env` and fill in.  NEVER commit `.env`.
# All secrets are read ONLY through src/lib/env.ts (typed + Zod-validated).
# -----------------------------------------------------------------------------

# --- KicksDB (StockX source) -------------------------------------------------
# Sent verbatim as the `Authorization` header (no "Bearer " prefix).
KICKS_SECRET=your-kicksdb-api-key
# Optional override; defaults to the public v3 base.
KICKS_BASE_URL=https://api.kicks.dev/v3

# --- WooCommerce REST (store) ------------------------------------------------
# Powers the Sync tab: pull live store state and push price updates over the
# Woo REST API (wp-json/wc/v3). The key needs Read/Write on products.
# Optional: without them the Sync tab is disabled and the hidden file
# round-trip flow (/preview) remains the fallback.
# WOO_BASE_URL=https://shop.example.com
# WOO_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOO_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GoldenSneakers feed -----------------------------------------------------
# The flat-assortment endpoint. Include your VAT/markup query params here:
# presented_price arrives FINAL and passes through the pricing engine unchanged.
# Products covered by the feed are OWNED by GoldenSneakers (sizes, prices,
# real stock). Optional: without these, upload the JSON manually on /feeds.
# GS_FEED_URL=https://www.goldensneakers.net/api/assortment-flat/?vat=22&markup=...
# GS_FEED_TOKEN=your-goldensneakers-bearer-token

# --- Scheduled runs ----------------------------------------------------------
# Shared secret for the cron endpoints (store pull / catalog refresh), e.g.
#   curl -X POST -H "Authorization: Bearer $CRON_SECRET" https://host/api/cron/pull-store
# Unset = scheduled endpoints disabled (on-demand buttons still work).
# CRON_SECRET=change-me

# --- Persistence -------------------------------------------------------------
# Matches docker-compose.yml defaults for local development.
DATABASE_URL=postgres://kicks:kicks@localhost:5432/kicks
REDIS_URL=redis://localhost:6379

# --- App ---------------------------------------------------------------------
# Default market and its currency mapping live in AppConfig; these are bootstrap
# fallbacks used before a config row exists.
DEFAULT_MARKET=IT
